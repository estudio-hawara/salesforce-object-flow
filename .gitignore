# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/

# Virtual environments
.venv/

# IDE
.idea/
.vscode/

# Tool caches
.ruff_cache/
.pytest_cache/
.mypy_cache/

# Local development files
/local/

# Compiled translations (regenerated via scripts/i18n.py compile).
# Keep the directory tracked (so hatch force-include resolves) but
# ignore everything inside except the placeholder.
/locale/*
!/locale/.gitkeep
/po/*.pot
