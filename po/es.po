#: salesforce_object_flow/pages/welcome.py:16
msgid "Welcome"
msgstr "Bienvenida"

#: salesforce_object_flow/pages/welcome.py:27
msgid ""
"Compose multi-object, transactional creates against the Salesforce REST "
"Composite API."
msgstr ""
"Compón creaciones multiobjeto y transaccionales contra la API REST "
"Composite de Salesforce."

#: salesforce_object_flow/pages/welcome.py:34
msgid "Status"
msgstr "Estado"

#: salesforce_object_flow/pages/welcome.py:36
#, python-brace-format
msgid "Version {version} — project scaffolding only."
msgstr "Versión {version} — solo andamiaje del proyecto."

#: salesforce_object_flow/pages/welcome.py:40
msgid "What's next"
msgstr "Próximos pasos"

#: salesforce_object_flow/pages/welcome.py:43
msgid ""
"The Composite API form lands in a follow-up release. For now, this window"
" confirms that the GTK4 + libadwaita stack is wired up correctly."
msgstr ""
"El formulario de la API Composite llegará en una próxima versión. Por "
"ahora, esta ventana confirma que el stack GTK4 + libadwaita está "
"correctamente cableado."

#: salesforce_object_flow/pages/connections.py:43
msgid ""
"In Setup, go to Apps → External Client Apps → External Client App "
"Manager, then click New External Client App."
msgstr ""
"En Setup, ve a Apps → External Client Apps → External Client App Manager "
"y haz clic en New External Client App."

#: salesforce_object_flow/pages/connections.py:46
msgid "External Client App Name: anything (e.g. “Salesforce Object Flow”)."
msgstr ""
"External Client App Name: cualquier valor (por ejemplo, «Salesforce "
"Object Flow»)."

#: salesforce_object_flow/pages/connections.py:47
msgid "Contact Email: your address."
msgstr "Contact Email: tu dirección de correo."

#: salesforce_object_flow/pages/connections.py:48
msgid "Enable OAuth Settings."
msgstr "Activa OAuth Settings."

#: salesforce_object_flow/pages/connections.py:49
#, python-brace-format
msgid "Callback URL — paste exactly: {callback_url}"
msgstr "Callback URL — pega exactamente: {callback_url}"

#: salesforce_object_flow/pages/connections.py:51
msgid ""
"Selected OAuth Scopes:\n"
"  • Manage user data via APIs (api)\n"
"  • Perform requests on your behalf at any time (refresh_token, "
"offline_access)"
msgstr ""
"Selected OAuth Scopes:\n"
"  • Manage user data via APIs (api)\n"
"  • Perform requests on your behalf at any time (refresh_token, "
"offline_access)"

#: salesforce_object_flow/pages/connections.py:57
msgid ""
"Enable “Require Proof Key for Code Exchange (PKCE) Extension for "
"Supported Authorization Flows”."
msgstr ""
"Activa «Require Proof Key for Code Exchange (PKCE) Extension for "
"Supported Authorization Flows»."

#: salesforce_object_flow/pages/connections.py:60
msgid "Disable “Require Secret for Web Server Flow”."
msgstr "Desactiva «Require Secret for Web Server Flow»."

#: salesforce_object_flow/pages/connections.py:62
msgid ""
"Disable “Require Secret for Refresh Token Flow” (it is enabled by default"
" — turn it off)."
msgstr ""
"Desactiva «Require Secret for Refresh Token Flow» (está activado por "
"defecto — desactívalo)."

#: salesforce_object_flow/pages/connections.py:65
msgid "Save. Wait 2–10 minutes for activation."
msgstr "Guarda. Espera de 2 a 10 minutos a que se active."

#: salesforce_object_flow/pages/connections.py:67
msgid ""
"Open the app's Settings → Consumer Key and Secret. Copy the Consumer Key "
"— that is your Client ID. The secret is not used by this app (PKCE)."
msgstr ""
"Abre los ajustes de la app → Consumer Key and Secret. Copia el Consumer "
"Key — ese es tu Client ID. El secret no lo usa esta aplicación (PKCE)."

#: salesforce_object_flow/pages/connections.py:77
#: salesforce_object_flow/pages/connections.py:165
#: salesforce_object_flow/pages/connections.py:245
msgid "Connections"
msgstr "Conexiones"

#: salesforce_object_flow/pages/connections.py:99
msgid "Add a new Salesforce connection"
msgstr "Añadir una nueva conexión de Salesforce"

#: salesforce_object_flow/pages/connections.py:117
msgid "Set up an External Client App"
msgstr "Configurar una External Client App"

#: salesforce_object_flow/pages/connections.py:120
msgid ""
"Salesforce Object Flow uses your own External Client App so tokens stay "
"scoped to your connection. Follow these one-time steps in Salesforce "
"Setup."
msgstr ""
"Salesforce Object Flow usa tu propia External Client App para que los "
"tokens queden ligados a tu conexión. Sigue estos pasos una sola vez en "
"Salesforce Setup."

#: salesforce_object_flow/pages/connections.py:125
msgid "Show step-by-step instructions"
msgstr "Mostrar instrucciones paso a paso"

#: salesforce_object_flow/pages/connections.py:153
msgid "Copy callback URL"
msgstr "Copiar URL de callback"

#: salesforce_object_flow/pages/connections.py:187
#: salesforce_object_flow/pages/objects.py:179
msgid "No connections yet"
msgstr "Aún no hay conexiones"

#: salesforce_object_flow/pages/connections.py:189
msgid "Click “Add connection” above to add your first Salesforce connection."
msgstr ""
"Pulsa «Añadir conexión» arriba para añadir tu primera conexión de "
"Salesforce."

#: salesforce_object_flow/pages/connections.py:197
#: salesforce_object_flow/pages/connections.py:479
