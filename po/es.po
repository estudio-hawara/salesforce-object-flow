#: salesforce_object_flow/pages/connections.py:395
msgid ""
"Salesforce Object Flow will revoke the access token and delete the stored"
" credentials for this connection. You can add it again later."
msgstr ""
"Salesforce Object Flow revocará el token de acceso y eliminará las "
"credenciales guardadas de esta conexión. Podrás volver a añadirla más "
"tarde."

#: salesforce_object_flow/pages/connections.py:398
